rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isHouseMember(houseId) {
      return isSignedIn()
        && (
          (
            exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && currentUserDoc().data.houseId == houseId
          )
          || exists(/databases/$(database)/documents/house_members/$(houseId + "_" + request.auth.uid))
        );
    }

    match /users/{userId} {
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email;

      allow read, update, delete: if isSignedIn()
        && request.auth.uid == userId;

      match /notifications/{notifId} {
        allow read, delete: if isSignedIn()
          && request.auth.uid == userId;

        allow create: if isSignedIn()
          && request.resource.data.keys().hasAll([
            'houseId', 'type', 'title', 'body',
            'actorUserId', 'actorName', 'createdAt'
          ])
          && request.resource.data.houseId is string
          && request.resource.data.type is string
          && request.resource.data.title is string
          && request.resource.data.body is string
          && request.resource.data.actorUserId is string
          && request.resource.data.actorName is string
          && isHouseMember(request.resource.data.houseId)
          && exists(/databases/$(database)/documents/users/$(userId))
          && get(/databases/$(database)/documents/users/$(userId)).data.houseId
            == request.resource.data.houseId;
      }
    }

    match /houses/{houseId} {
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.membersCount == 1;

      allow read: if isSignedIn() && isHouseMember(houseId);

      allow update: if isSignedIn()
        && (
          resource.data.ownerId == request.auth.uid
          || (
            request.resource.data.ownerId == resource.data.ownerId
            && request.resource.data.inviteCode == resource.data.inviteCode
            && request.resource.data.name == resource.data.name
            && request.resource.data.memberLimit == resource.data.memberLimit
            && request.resource.data.currency == resource.data.currency
            && request.resource.data.theme == resource.data.theme
            && request.resource.data.houseId == resource.data.houseId
            && request.resource.data.membersCount == resource.data.membersCount + 1
          )
          || (
            isHouseMember(houseId)
            && request.resource.data.ownerId == resource.data.ownerId
            && request.resource.data.inviteCode == resource.data.inviteCode
            && request.resource.data.name == resource.data.name
            && request.resource.data.memberLimit == resource.data.memberLimit
            && request.resource.data.currency == resource.data.currency
            && request.resource.data.theme == resource.data.theme
            && request.resource.data.houseId == resource.data.houseId
            && request.resource.data.membersCount == resource.data.membersCount - 1
          )
        );

      allow delete: if isSignedIn()
        && resource.data.ownerId == request.auth.uid;
    }

    match /house_members/{membershipId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;

      allow read: if isSignedIn();

      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      allow delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }

    match /chores/{choreId} {
      allow create: if isSignedIn()
        && isHouseMember(request.resource.data.houseId);

      allow read: if isSignedIn()
        && isHouseMember(resource.data.houseId);

      allow update, delete: if isSignedIn()
        && isHouseMember(resource.data.houseId);
    }

    match /expenses/{expenseId} {
      allow create: if isSignedIn()
        && isHouseMember(request.resource.data.houseId)
        && request.resource.data.paidBy == request.auth.uid;

      allow read: if isSignedIn()
        && isHouseMember(resource.data.houseId);

      allow update, delete: if isSignedIn()
        && isHouseMember(resource.data.houseId)
        && (
          resource.data.paidBy == request.auth.uid
          || request.auth.uid in resource.data.participantUserIds
        );
    }

    match /shopping_items/{itemId} {
      allow create: if isSignedIn()
        && isHouseMember(request.resource.data.houseId);

      allow read: if isSignedIn()
        && isHouseMember(resource.data.houseId);

      allow update, delete: if isSignedIn()
        && isHouseMember(resource.data.houseId);
    }

  }
}
